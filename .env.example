# Copy this file to .env and fill in your Azure SQL connection string
# Never commit .env to source control

NOMADSTAYS_DB_CONNECTION="Server=tcp:your-server.database.windows.net,1433;Database=your-database;Persist Security Info=False;User ID=your-user;Password=your-password;MultipleActiveResultSets=False;Encrypt=True;TrustServerCertificate=False;Connection Timeout=30;"

# Required only for the write tools (updateStayDetail, createStayRoom, updateStayRoom,
# createStayPackage, updateStayPackage, updateStayOrganisationalData, updateHostBusinessProfile).
# Issue a token at https://nomadstays.com/siteadmin/mcp-tokens-admin — it scopes every write
# to the Stays owned by that one host account.
NOMADSTAYS_MCP_AGENT_TOKEN="mcp_..."

# OPTIONAL: override the base URL for the write API (defaults to https://nomadstays.com/api/mcp-agent)
# NOMADSTAYS_MCP_AGENT_BASE_URL="https://localhost:7200/api/mcp-agent"
